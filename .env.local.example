# Clé API football-data.org (https://www.football-data.org/client/register)
# Copier ce fichier en `.env.local` puis renseigner les valeurs.
FOOTBALL_DATA_API_KEY=

# Supabase (V2) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé secrète serveur (calcul du classement) — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# Joueur IA (V2) — pronostics automatiques
ANTHROPIC_API_KEY=
AI_BOT_USER_ID=
# Secret protégeant la route cron (Vercel l'envoie automatiquement en en-tête)
CRON_SECRET=
