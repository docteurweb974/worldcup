# Clé API football-data.org (https://www.football-data.org/client/register)
# Copier ce fichier en `.env.local` puis renseigner les valeurs.
FOOTBALL_DATA_API_KEY=

# Supabase (V2) — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé secrète serveur (calcul du classement) — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=

# ───────────────────────────────────────────────────────────────────────
# Joueur IA « Agent IA 🤖 » — script scripts/ai-predict.mjs
# Lancé par GitHub Actions (.github/workflows/ai-predict.yml), pas par le site.
# Ces variables sont à déclarer comme « Secrets » du dépôt GitHub
# (Settings → Secrets and variables → Actions), avec les mêmes valeurs.
# ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# URL Supabase (même valeur que NEXT_PUBLIC_SUPABASE_URL)
SUPABASE_URL=
# Identifiant (UUID) du compte du bot dans la table profiles
AI_BOT_USER_ID=
# Optionnel — réglages par défaut codés dans le script :
#   AI_RESEARCH_MODEL=claude-sonnet-4-6   (recherche web + Opta)
#   AI_SCORING_MODEL=claude-haiku-4-5      (calcul des scores)
#   AI_WINDOW_HOURS=72   AI_MAX_SEARCHES=2
